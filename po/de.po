#, python-brace-format
msgid ""
"Batch metadata for '{name}' is missing required field: 'baseline'.\n"
"The metadata file may be corrupted."
msgstr ""
"Batch Metadaten for '{name}' is missing required field: 'baseZeile'.\n"
"The Metadatendatei may be corrupted."

