msgstr "⚠ Warnung: Stash konnte nicht sauber angewendet werden: {}"

#: src/git_stage_batch/commands/abort.py:84
msgid "Restored: {}"
msgstr "Wiederhergestellt: {}"

#: src/git_stage_batch/commands/abort.py:102
