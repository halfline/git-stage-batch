msgid_plural "✓ Staged {count} hunks from {files}"
msgstr[0] "✓ Staged {count} hunk from {files}"
msgstr[1] "✓ Staged {count} hunks from {files}"

#: src/git_stage_batch/cli/argument_parser.py:392
