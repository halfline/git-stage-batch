#: src/git_stage_batch/batch/display.py:158
#, python-brace-format
msgid "... {count} more line ..."
msgid_plural "... {count} more lines ..."
msgstr[0] "... {count} ligne de plus ..."
msgstr[1] "... {count} lignes de plus ..."

#: src/git_stage_batch/batch/merge.py:146
#, python-brace-format
msgid "Cannot reliably place claimed line {line}: file completely rewritten"
msgstr "Impossible de placer de façon fiable la ligne revendiquée {line} : le fichier a été entièrement réécrit"

#: src/git_stage_batch/batch/merge.py:154
#, python-brace-format
msgid "Claimed line {line} is out of range (batch source has {count} lines)"
msgstr "La ligne revendiquée {line} est hors limites (la source du lot contient {count} lignes)"

#: src/git_stage_batch/batch/merge.py:176
#, python-brace-format
msgid "Cannot reliably place claimed line {line}: surrounding context lost"
msgstr "Impossible de placer de façon fiable la ligne revendiquée {line} : le contexte environnant est perdu"

#: src/git_stage_batch/batch/merge.py:187
#, python-brace-format
msgid "Deletion after line {line} is out of range"
msgstr "La suppression après la ligne {line} est hors limites"

#: src/git_stage_batch/batch/merge.py:199
#, python-brace-format
msgid ""
"Cannot determine deletion position after line {line}: anchor and neighbors "
"missing"
msgstr "Impossible de déterminer la position de suppression après la ligne {line} : l'ancre et les lignes voisines manquent"

#: src/git_stage_batch/batch/merge.py:268
#: src/git_stage_batch/batch/merge.py:969
msgid "Batch was created from a different version of the file"
msgstr "Le lot a été créé à partir d'une version différente du fichier"

#: src/git_stage_batch/batch/merge.py:732
#, python-brace-format
msgid "Cannot satisfy claimed line {line}: removed by absence constraints"
msgstr "Impossible de satisfaire la ligne revendiquée {line} : supprimée par des contraintes d'absence"

#: src/git_stage_batch/batch/merge.py:804
#, python-brace-format
msgid ""
"Cannot locate anchor boundary after source line {line}: anchor not present "
"in realized content"
msgstr "Impossible de trouver la limite d'ancre après la ligne source {line} : l'ancre n'est pas présente dans le contenu réalisé"

#: src/git_stage_batch/batch/merge.py:813
#, python-brace-format
msgid ""
"Anchor ambiguity: source line {line} appears {count} times in realized "
"content but none are claimed"
msgstr "Ambiguïté d'ancre : la ligne source {line} apparaît {count} fois dans le contenu réalisé, mais aucune occurrence n'est revendiquée"

#: src/git_stage_batch/batch/merge.py:819
#, python-brace-format
msgid "Anchor ambiguity: source line {line} claimed {count} times"
msgstr "Ambiguïté d'ancre : la ligne source {line} est revendiquée {count} fois"

#: src/git_stage_batch/batch/merge.py:1412
#, python-brace-format
msgid "Cannot discard source line {line}: no baseline restoration region found"
msgstr "Impossible d'écarter la ligne source {line} : aucune région de restauration de référence trouvée"

#: src/git_stage_batch/batch/merge.py:1419
#, python-brace-format
msgid "Cannot discard source line {line}: baseline restoration is ambiguous"
msgstr "Impossible d'écarter la ligne source {line} : la restauration de référence est ambiguë"

#: src/git_stage_batch/batch/merge.py:1434
#, python-brace-format
msgid "Source line {line} offset {offset} outside region bounds"
msgstr "Décalage {offset} de la ligne source {line} hors des limites de la région"

#: src/git_stage_batch/batch/merge.py:1452
#, python-brace-format
msgid ""
"Cannot discard partial ownership of by-hunk replace region (source lines "
"{start}-{end}): batch owns {owned} of {total} lines"
msgstr "Impossible d'écarter une propriété partielle de la région de remplacement par fragment (lignes source {start}-{end}) : le lot possède {owned} lignes sur {total}"

#: src/git_stage_batch/batch/merge.py:1471
#, python-brace-format
msgid "Unknown region kind: {kind}"
msgstr "Type de région inconnu : {kind}"

#: src/git_stage_batch/batch/merge.py:1675
#, python-brace-format
msgid ""
"Ownership conflict: line {line} is claimed by one batch but would be deleted "
"by another (content: {preview})"
msgstr "Conflit de propriété : la ligne {line} est revendiquée par un lot mais serait supprimée par un autre (contenu : {preview})"

#: src/git_stage_batch/batch/metadata_validation.py:31
#, python-brace-format
msgid ""
"The git-stage-batch metadata directory is missing.\n"
"Expected directory: {dir}\n"
"This may indicate the batch session was not initialized properly."
msgstr "Le répertoire de métadonnées git-stage-batch est manquant.\nRépertoire attendu : {dir}\nCela peut indiquer que la session de lots n'a pas été initialisée correctement."

#: src/git_stage_batch/batch/metadata_validation.py:40
#, python-brace-format
msgid "The git-stage-batch metadata path exists but is not a directory: {dir}"
msgstr "Le chemin des métadonnées git-stage-batch existe mais n'est pas un répertoire : {dir}"

#: src/git_stage_batch/batch/metadata_validation.py:68
#, python-brace-format
msgid ""
"Batch metadata is missing or corrupted for '{name}'.\n"
"The batch ref exists (refs/batches/{name}) but metadata file is missing.\n"
"Expected metadata file: {file}\n"
"The batch may not be recoverable automatically."
msgstr "Les métadonnées du lot '{name}' sont manquantes ou corrompues.\nLa référence du lot existe (refs/batches/{name}) mais le fichier de métadonnées manque.\nFichier de métadonnées attendu : {file}\nLe lot pourrait ne pas être récupérable automatiquement."

#: src/git_stage_batch/batch/metadata_validation.py:100
#, python-brace-format
msgid ""
"Batch metadata for '{name}' is missing required field: 'baseline'.\n"
"The metadata file may be corrupted."
msgstr "Il manque le champ obligatoire 'baseline' dans les métadonnées du lot '{name}'.\nLe fichier de métadonnées peut être corrompu."

#: src/git_stage_batch/batch/metadata_validation.py:107
#: src/git_stage_batch/batch/metadata_validation.py:294
#, python-brace-format
msgid ""
"Batch '{name}' has no baseline commit.\n"
"The batch metadata exists but baseline is null or missing.\n"
"This indicates corrupted or incomplete batch state."
msgstr "Le lot '{name}' n'a aucun commit de référence.\nLes métadonnées du lot existent mais la référence est nulle ou manquante.\nCela indique un état de lot corrompu ou incomplet."

#: src/git_stage_batch/batch/metadata_validation.py:120
#, python-brace-format
msgid ""
"Batch '{name}' has invalid baseline commit: {baseline}\n"
"The baseline commit does not exist in the repository.\n"
"The batch metadata may be corrupted."
msgstr "Le lot '{name}' a un commit de référence non valide : {baseline}\nLe commit de référence n'existe pas dans le dépôt.\nLes métadonnées du lot peuvent être corrompues."

#: src/git_stage_batch/batch/metadata_validation.py:133
#, python-brace-format
msgid ""
"Batch metadata for '{name}' has invalid 'files' field (expected object).\n"
"The metadata file may be corrupted."
msgstr "Les métadonnées du lot '{name}' ont un champ 'files' non valide (objet attendu).\nLe fichier de métadonnées peut être corrompu."

#: src/git_stage_batch/batch/metadata_validation.py:141
#, python-brace-format
msgid ""
"Batch metadata for '{name}' has invalid file entry for '{file}'.\n"
"The metadata file may be corrupted."
msgstr "Les métadonnées du lot '{name}' ont une entrée de fichier non valide pour '{file}'.\nLe fichier de métadonnées peut être corrompu."

#: src/git_stage_batch/batch/metadata_validation.py:154
#, python-brace-format
msgid ""
"Batch metadata for '{name}' is missing 'batch_source_commit' for file "
"'{file}'.\n"
"The metadata file may be corrupted."
msgstr "Il manque 'batch_source_commit' pour le fichier '{file}' dans les métadonnées du lot '{name}'.\nLe fichier de métadonnées peut être corrompu."

#: src/git_stage_batch/batch/metadata_validation.py:170
#, python-brace-format
msgid ""
"Batch '{name}' has invalid batch_source_commit for file '{file}': {commit}\n"
"The batch source commit does not exist in the repository.\n"
"The batch metadata may be corrupted."
msgstr "Le lot '{name}' a un batch_source_commit non valide pour le fichier '{file}' : {commit}\nLe commit source du lot n'existe pas dans le dépôt.\nLes métadonnées du lot peuvent être corrompues."

#: src/git_stage_batch/batch/metadata_validation.py:228
#, python-brace-format
msgid ""
"Batch metadata for '{name}' is corrupted (invalid JSON).\n"
"Metadata file: {file}\n"
"Error: {error}"
msgstr "Les métadonnées du lot '{name}' sont corrompues (JSON non valide).\nFichier de métadonnées : {file}\nErreur : {error}"

#: src/git_stage_batch/batch/metadata_validation.py:238
#, python-brace-format
msgid ""
"Failed to read batch metadata for '{name}'.\n"
"Metadata file: {file}\n"
"Error: {error}"
msgstr "Impossible de lire les métadonnées du lot '{name}'.\nFichier de métadonnées : {file}\nErreur : {error}"

#: src/git_stage_batch/batch/operations.py:27
#, python-brace-format
msgid "Batch '{name}' already exists"
msgstr "Le lot '{name}' existe déjà"

#: src/git_stage_batch/batch/operations.py:76
#: src/git_stage_batch/batch/operations.py:92
#: src/git_stage_batch/commands/apply_from.py:90
#: src/git_stage_batch/commands/discard_from.py:75
#: src/git_stage_batch/commands/include_from.py:40
#: src/git_stage_batch/commands/reset.py:58
#: src/git_stage_batch/commands/show_from.py:35
#: src/git_stage_batch/commands/sift.py:193
#, python-brace-format
msgid "Batch '{name}' does not exist"
msgstr "Le lot '{name}' n'existe pas"

#: src/git_stage_batch/batch/ownership.py:552
msgid "Invalid replacement unit: must have both claimed lines and deletions"
msgstr "Unité de remplacement non valide : elle doit contenir des lignes revendiquées et des suppressions"

#: src/git_stage_batch/batch/ownership.py:557
msgid "Invalid deletion-only unit: must have deletions but no claimed lines"
msgstr "Unité de suppression seule non valide : elle doit contenir des suppressions mais aucune ligne revendiquée"

#: src/git_stage_batch/batch/ownership.py:593
#, python-brace-format
msgid ""
"Cannot partially select atomic ownership unit.\n"
"Unit kind: {kind}{reason}\n"
"Selected: {selected_ids}"
msgstr "Impossible de sélectionner partiellement une unité de propriété atomique.\nType d'unité : {kind}{reason}\nSélection : {selected_ids}"

#: src/git_stage_batch/batch/selection.py:53
#: src/git_stage_batch/commands/discard.py:307
#: src/git_stage_batch/commands/include.py:290
#: src/git_stage_batch/commands/show.py:51
msgid "No selected hunk. Run 'show' first or specify file path."
msgstr "Aucun fragment sélectionné. Exécutez d'abord 'show' ou indiquez un chemin de fichier."

#: src/git_stage_batch/batch/selection.py:94
#, python-brace-format
msgid ""
"Line-level {operation} (--line) requires single-file context.\n"
"Use --file to specify a file, or run 'show --from {name}' first to select a "
"file."
msgstr "{operation} au niveau des lignes (--line) nécessite un contexte à fichier unique.\nUtilisez --file pour indiquer un fichier, ou exécutez d'abord 'show --from {name}' pour sélectionner un fichier."

#: src/git_stage_batch/batch/selection.py:135
msgid ""
"These lines form a replacement (deletion + addition) and must be selected "
"together."
msgstr "Ces lignes forment un remplacement (suppression + ajout) et doivent être sélectionnées ensemble."

#: src/git_stage_batch/batch/selection.py:137
msgid "These lines form a deletion and must be selected together."
msgstr "Ces lignes forment une suppression et doivent être sélectionnées ensemble."

#: src/git_stage_batch/batch/selection.py:139
msgid "These lines must be selected together."
msgstr "Ces lignes doivent être sélectionnées ensemble."

#: src/git_stage_batch/batch/selection.py:142
#, python-brace-format
msgid ""
"{explanation}\n"
"Use: --line {range}"
msgstr "{explanation}\nUse: --line {range}"

#: src/git_stage_batch/batch/selection.py:148
#, python-brace-format
msgid "Failed to {operation} batch '{name}': {error}"
msgstr "Échec de l'opération {operation} sur le lot '{name}' : {error}"

#: src/git_stage_batch/batch/validation.py:13
msgid "Batch name cannot be empty"
msgstr "Le nom du lot ne peut pas être vide"

#: src/git_stage_batch/batch/validation.py:19
#, python-brace-format
msgid "Batch name cannot contain: {char}"
msgstr "Le nom du lot ne peut pas contenir : {char}"

#: src/git_stage_batch/batch/validation.py:23
msgid "Batch name cannot start with '.'"
msgstr "Le nom du lot ne peut pas commencer par '.'"

#: src/git_stage_batch/cli/argument_parser.py:66
msgid "Hunk-by-hunk and line-by-line staging for git"
msgstr "Indexation section par section et ligne par ligne pour git"

#: src/git_stage_batch/cli/argument_parser.py:79
msgid "Run as if started in path"
msgstr "Exécuter comme si le démarrage avait eu lieu dans le chemin"

#: src/git_stage_batch/cli/argument_parser.py:85
msgid "Start interactive mode"
msgstr "Démarrer le mode interactif"

#: src/git_stage_batch/cli/argument_parser.py:90
msgid "Available commands"
msgstr "Commandes disponibles"

#: src/git_stage_batch/cli/argument_parser.py:96
msgid "Start a new batch staging session"
msgstr "Démarrer une nouvelle session d'indexation par lot"

#: src/git_stage_batch/cli/argument_parser.py:104
msgid "Number of context lines in diff output (default: 3)"
msgstr "Nombre de lignes de contexte dans la sortie de diff (par défaut : 3)"

#: src/git_stage_batch/cli/argument_parser.py:111
msgid "Start interactive hunk-by-hunk mode"
msgstr "Démarrer le mode interactif section par section"

#: src/git_stage_batch/cli/argument_parser.py:118
msgid "Stop the selected session and clear state"
msgstr "Arrêter la session actuelle et effacer l'état"

#: src/git_stage_batch/cli/argument_parser.py:126
msgid "Clear state and start a fresh pass"
msgstr "Effacer l'état et démarrer une nouvelle passe"

#: src/git_stage_batch/cli/argument_parser.py:133
msgid "Show the selected hunk"
msgstr "Afficher la section actuelle"

#: src/git_stage_batch/cli/argument_parser.py:139
msgid "Show changes from batch"
msgstr "Afficher les modifications du lot"

#: src/git_stage_batch/cli/argument_parser.py:146
msgid "Show only specific line IDs (e.g., '1,3,5-7')"
msgstr "Afficher seulement certains identifiants de ligne (par ex. '1,3,5-7')"

#: src/git_stage_batch/cli/argument_parser.py:154
msgid ""
"Operate on entire file (live working tree state). If PATH omitted, uses "
"selected hunk's file. With --line, operates on line IDs from entire file."
msgstr "Opérer sur tout le fichier (état actuel de l'arbre de travail). Si CHEMIN est omis, utilise le fichier du fragment sélectionné. Avec --line, opère sur les identifiants de ligne de tout le fichier."

#: src/git_stage_batch/cli/argument_parser.py:161
#: src/git_stage_batch/cli/argument_parser.py:178
msgid "Output JSON for scripting instead of human-readable text"
msgstr "Produire du JSON pour les scripts au lieu d'un texte lisible par l'humain"

#: src/git_stage_batch/cli/argument_parser.py:173
msgid "Show selected session status"
msgstr "Afficher l'état de la session actuelle"

#: src/git_stage_batch/cli/argument_parser.py:186
msgid "Stage the selected hunk"
msgstr "Indexer la section actuelle"

#: src/git_stage_batch/cli/argument_parser.py:193
msgid "Stage only specific line IDs (e.g., '1,3,5-7')"
msgstr "Indexer uniquement des IDs de ligne spécifiques (ex. : '1,3,5-7')"

#: src/git_stage_batch/cli/argument_parser.py:201
msgid ""
"Operate on entire file (live working tree state). If PATH omitted, uses "
"selected hunk's file. Without --line, stages entire file. With --line, "
"operates on line IDs from entire file."
msgstr "Opérer sur tout le fichier (état actuel de l'arbre de travail). Si CHEMIN est omis, utilise le fichier du fragment sélectionné. Sans --line, indexe tout le fichier. Avec --line, opère sur les identifiants de ligne de tout le fichier."

#: src/git_stage_batch/cli/argument_parser.py:210
msgid "Include changes from batch"
msgstr "Inclure les modifications du lot"

#: src/git_stage_batch/cli/argument_parser.py:216
msgid "Include changes to batch"
msgstr "Inclure les modifications vers le lot"

#: src/git_stage_batch/cli/argument_parser.py:230
msgid "Skip the selected hunk without staging"
msgstr "Ignorer la section actuelle sans indexer"

#: src/git_stage_batch/cli/argument_parser.py:237
msgid "Skip only specific line IDs (e.g., '1,3,5-7')"
msgstr "Ignorer uniquement des IDs de ligne spécifiques (ex. : '1,3,5-7')"

#: src/git_stage_batch/cli/argument_parser.py:242
msgid "Skip all hunks from the selected file"
msgstr "Ignorer toutes les sections du fichier actuel"

#: src/git_stage_batch/cli/argument_parser.py:254
msgid "Remove the selected hunk from working tree"
msgstr "Retirer la section actuelle de l'arbre de travail"

#: src/git_stage_batch/cli/argument_parser.py:261
msgid "Discard only specific line IDs (e.g., '1,3,5-7')"
msgstr "Abandonner uniquement des IDs de ligne spécifiques (ex. : '1,3,5-7')"

#: src/git_stage_batch/cli/argument_parser.py:269
msgid ""
"Operate on entire file (live working tree state). If PATH omitted, uses "
"selected hunk's file. Without --line, discards entire file. With --line, "
"operates on line IDs from entire file."
msgstr "Opérer sur tout le fichier (état actuel de l'arbre de travail). Si CHEMIN est omis, utilise le fichier du fragment sélectionné. Sans --line, écarte tout le fichier. Avec --line, opère sur les identifiants de ligne de tout le fichier."

#: src/git_stage_batch/cli/argument_parser.py:278
msgid "Discard changes from batch"
msgstr "Abandonner les modifications du lot"

#: src/git_stage_batch/cli/argument_parser.py:284
msgid "Discard changes to batch"
msgstr "Abandonner les modifications vers le lot"

#: src/git_stage_batch/cli/argument_parser.py:297
msgid "Restore repository to pre-session state"
msgstr "Restaurer le dépôt à l'état pré-session"

#: src/git_stage_batch/cli/argument_parser.py:305
msgid "Permanently exclude a file (adds to .gitignore)"
msgstr "Exclure définitivement un fichier (ajoute à .gitignore)"

#: src/git_stage_batch/cli/argument_parser.py:309
msgid "Path to the file to block"
msgstr "Chemin vers le fichier à bloquer"

#: src/git_stage_batch/cli/argument_parser.py:317
msgid "Remove a file from the blocked list"
msgstr "Retirer un fichier de la liste des bloqués"

#: src/git_stage_batch/cli/argument_parser.py:321
msgid "Path to the file to unblock"
msgstr "Chemin vers le fichier à débloquer"

#: src/git_stage_batch/cli/argument_parser.py:329
msgid "Suggest which commit the selected hunk should be fixed up to"
msgstr "Suggérer quelle validation la section actuelle devrait corriger"

#: src/git_stage_batch/cli/argument_parser.py:336
msgid "Analyze only specific line IDs (e.g., '1,3,5-7')"
msgstr "Analyser uniquement des IDs de ligne spécifiques (ex. : '1,3,5-7')"

#: src/git_stage_batch/cli/argument_parser.py:341
msgid "Reset state and start search over from most recent"
msgstr "Réinitialiser l'état et recommencer la recherche depuis le plus récent"

#: src/git_stage_batch/cli/argument_parser.py:346
msgid "Clear state and exit without showing candidates"
msgstr "Effacer l'état et quitter sans afficher les candidats"

#: src/git_stage_batch/cli/argument_parser.py:351
msgid "Re-show the last candidate without advancing"
msgstr "Réafficher le dernier candidat sans avancer"

#: src/git_stage_batch/cli/argument_parser.py:357
#, python-brace-format
msgid "Git ref to use as lower bound for commit search (default: @{upstream})"
msgstr ""
"Référence Git à utiliser comme limite inférieure pour la recherche de "
"validation (par défaut : @{upstream})"

#: src/git_stage_batch/cli/argument_parser.py:378
msgid "Create a new batch"
msgstr "Créer un nouveau lot"

#: src/git_stage_batch/cli/argument_parser.py:382
msgid "Name of the batch to create"
msgstr "Nom du lot à créer"

#: src/git_stage_batch/cli/argument_parser.py:387
msgid "Optional description for the batch"
msgstr "Description facultative du lot"

#: src/git_stage_batch/cli/argument_parser.py:394
msgid "List all batches"
msgstr "Lister tous les lots"

#: src/git_stage_batch/cli/argument_parser.py:401
msgid "Delete a batch"
msgstr "Supprimer un lot"

#: src/git_stage_batch/cli/argument_parser.py:405
msgid "Name of the batch to delete"
msgstr "Nom du lot à supprimer"

#: src/git_stage_batch/cli/argument_parser.py:412
msgid "Add or update batch description"
msgstr "Ajouter ou mettre à jour la description du lot"

#: src/git_stage_batch/cli/argument_parser.py:416
msgid "Name of the batch"
msgstr "Nom du lot"

#: src/git_stage_batch/cli/argument_parser.py:420
msgid "Description text"
msgstr "Texte de description"

#: src/git_stage_batch/cli/argument_parser.py:427
msgid "Apply batch changes to working tree"
msgstr "Appliquer les modifications du lot à l'arbre de travail"

#: src/git_stage_batch/cli/argument_parser.py:434
msgid "Apply changes from batch to working tree"
msgstr "Appliquer les modifications du lot à l'arbre de travail"

#: src/git_stage_batch/cli/argument_parser.py:441
msgid "Apply only specific line IDs (e.g., '1,3,5-7')"
msgstr "Appliquer seulement certains identifiants de ligne (par ex. '1,3,5-7')"

#: src/git_stage_batch/cli/argument_parser.py:449
msgid ""
"Operate on entire file from batch. If PATH omitted, uses first file in batch "
"(sorted order). With --line, operates on line IDs from entire file."
msgstr "Opérer sur tout le fichier depuis le lot. Si CHEMIN est omis, utilise le premier fichier du lot (ordre trié). Avec --line, opère sur les identifiants de ligne de tout le fichier."

#: src/git_stage_batch/cli/argument_parser.py:458
#: src/git_stage_batch/cli/argument_parser.py:465
msgid "Remove claims from batch"
msgstr "Supprimer les réclamations du lot"

#: src/git_stage_batch/cli/argument_parser.py:471
msgid "Move reset claims to another batch"
msgstr "Déplacer les revendications réinitialisées vers un autre lot"

#: src/git_stage_batch/cli/argument_parser.py:478
msgid "Reset only specific line IDs (e.g., '1,3,5-7')"
msgstr ""
"Réinitialiser uniquement des IDs de ligne spécifiques (par ex., '1,3,5-7')"

#: src/git_stage_batch/cli/argument_parser.py:486
msgid ""
"Operate on entire file from batch. If PATH omitted, uses selected hunk's "
"file. With --line, operates on line IDs from entire file."
msgstr "Opérer sur tout le fichier depuis le lot. Si CHEMIN est omis, utilise le fichier du fragment sélectionné. Avec --line, opère sur les identifiants de ligne de tout le fichier."

#: src/git_stage_batch/cli/argument_parser.py:495
msgid "Remove already-present portions from a batch"
msgstr "Retirer d'un lot les parties déjà présentes"

#: src/git_stage_batch/cli/argument_parser.py:502
msgid "Source batch to sift"
msgstr "Lot source à tamiser"

#: src/git_stage_batch/cli/argument_parser.py:509
msgid "Destination batch (may equal source for in-place sift)"
msgstr "Lot de destination (peut être identique à la source pour un tamisage sur place)"

#: src/git_stage_batch/cli/dispatch.py:24
#: src/git_stage_batch/commands/status.py:71
msgid "No batch staging session in progress."
msgstr "Aucune session d'indexation par lot en cours."

#: src/git_stage_batch/cli/dispatch.py:25
#: src/git_stage_batch/commands/status.py:72
msgid "Run 'git-stage-batch start' to begin."
msgstr "Exécutez 'git-stage-batch start' pour commencer."

#: src/git_stage_batch/commands/abort.py:32
msgid "No session to abort. Abort state not found."
msgstr "Aucune session à abandonner. État d'abandon introuvable."

#: src/git_stage_batch/commands/abort.py:50
