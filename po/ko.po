#: src/git_stage_batch/cli/argument_parser.py:66
msgid "Hunk-by-hunk and line-by-line staging for git"
msgstr "git을 위한 헝크별 및 줄별 스테이징"

#: src/git_stage_batch/cli/argument_parser.py:78
msgid "Start interactive mode"
msgstr "대화형 모드 시작"

#: src/git_stage_batch/cli/argument_parser.py:83
msgid "Available commands"
msgstr "사용 가능한 명령"

#: src/git_stage_batch/cli/argument_parser.py:89
msgid "Start a new batch staging session"
msgstr "새 배치 스테이징 세션 시작"

#: src/git_stage_batch/cli/argument_parser.py:97
msgid "Number of context lines in diff output (default: 3)"
msgstr "diff 출력의 컨텍스트 줄 수 (기본값: 3)"

#: src/git_stage_batch/cli/argument_parser.py:104
msgid "Start interactive hunk-by-hunk mode"
msgstr "대화형 헝크별 모드 시작"

#: src/git_stage_batch/cli/argument_parser.py:111
msgid "Stop the current session and clear state"
msgstr "현재 세션 중지 및 상태 초기화"

#: src/git_stage_batch/cli/argument_parser.py:119
msgid "Clear state and start a fresh pass"
msgstr "상태를 초기화하고 새로운 패스 시작"

#: src/git_stage_batch/cli/argument_parser.py:126
msgid "Show the current hunk"
msgstr "현재 헝크 표시"

#: src/git_stage_batch/cli/argument_parser.py:132
msgid "Show changes from batch"
msgstr "배치의 변경사항 표시"

#: src/git_stage_batch/cli/argument_parser.py:143
msgid "Show current session status"
msgstr "현재 세션 상태 표시"

#: src/git_stage_batch/cli/argument_parser.py:151
msgid "Stage the current hunk"
msgstr "현재 헝크 스테이징"

#: src/git_stage_batch/cli/argument_parser.py:158
msgid "Stage only specific line IDs (e.g., '1,3,5-7')"
msgstr "특정 줄 ID만 스테이징 (예: '1,3,5-7')"

#: src/git_stage_batch/cli/argument_parser.py:163
msgid "Stage the entire file containing the current hunk"
msgstr "현재 헝크를 포함하는 전체 파일 스테이징"

#: src/git_stage_batch/cli/argument_parser.py:169
msgid "Include changes from batch"
msgstr "배치에서 변경사항 포함"

#: src/git_stage_batch/cli/argument_parser.py:175
msgid "Include changes to batch"
msgstr "배치에 변경사항 포함"

#: src/git_stage_batch/cli/argument_parser.py:189
msgid "Skip the current hunk without staging"
msgstr "스테이징하지 않고 현재 헝크 건너뛰기"

#: src/git_stage_batch/cli/argument_parser.py:196
msgid "Skip only specific line IDs (e.g., '1,3,5-7')"
msgstr "특정 줄 ID만 건너뛰기 (예: '1,3,5-7')"

#: src/git_stage_batch/cli/argument_parser.py:201
msgid "Skip all hunks from the current file"
msgstr "현재 파일의 모든 헝크 건너뛰기"

#: src/git_stage_batch/cli/argument_parser.py:213
msgid "Remove the current hunk from working tree"
msgstr "작업 트리에서 현재 헝크 제거"

#: src/git_stage_batch/cli/argument_parser.py:220
msgid "Discard only specific line IDs (e.g., '1,3,5-7')"
msgstr "특정 줄 ID만 폐기 (예: '1,3,5-7')"

#: src/git_stage_batch/cli/argument_parser.py:225
msgid "Discard the entire file containing the current hunk"
msgstr "현재 헝크를 포함하는 전체 파일 폐기"

#: src/git_stage_batch/cli/argument_parser.py:231
msgid "Discard changes from batch"
msgstr "배치에서 변경사항 폐기"

#: src/git_stage_batch/cli/argument_parser.py:237
msgid "Discard changes to batch"
msgstr "배치에 변경사항 폐기"

#: src/git_stage_batch/cli/argument_parser.py:250
msgid "Restore repository to pre-session state"
msgstr "저장소를 세션 이전 상태로 복원"

#: src/git_stage_batch/cli/argument_parser.py:258
msgid "Permanently exclude a file (adds to .gitignore)"
msgstr "파일을 영구적으로 제외 (.gitignore에 추가)"

#: src/git_stage_batch/cli/argument_parser.py:262
msgid "Path to the file to block"
msgstr "차단할 파일 경로"

#: src/git_stage_batch/cli/argument_parser.py:270
msgid "Remove a file from the blocked list"
msgstr "차단 목록에서 파일 제거"

#: src/git_stage_batch/cli/argument_parser.py:274
msgid "Path to the file to unblock"
msgstr "차단 해제할 파일 경로"

#: src/git_stage_batch/cli/argument_parser.py:282
msgid "Suggest which commit the current hunk should be fixed up to"
msgstr "현재 헝크가 수정되어야 할 커밋 제안"

#: src/git_stage_batch/cli/argument_parser.py:289
msgid "Analyze only specific line IDs (e.g., '1,3,5-7')"
msgstr "특정 줄 ID만 분석 (예: '1,3,5-7')"

#: src/git_stage_batch/cli/argument_parser.py:294
msgid "Reset state and start search over from most recent"
msgstr "상태를 재설정하고 가장 최근부터 검색 재시작"

#: src/git_stage_batch/cli/argument_parser.py:299
msgid "Clear state and exit without showing candidates"
msgstr "후보를 표시하지 않고 상태 초기화 및 종료"

#: src/git_stage_batch/cli/argument_parser.py:304
msgid "Re-show the last candidate without advancing"
msgstr "진행하지 않고 마지막 후보 다시 표시"

#: src/git_stage_batch/cli/argument_parser.py:310
#, python-brace-format
msgid "Git ref to use as lower bound for commit search (default: @{upstream})"
msgstr "커밋 검색의 하한으로 사용할 Git ref (기본값: @{upstream})"

#: src/git_stage_batch/cli/argument_parser.py:331
msgid "Create a new batch"
msgstr "새 배치 생성"

#: src/git_stage_batch/cli/argument_parser.py:335
msgid "Name of the batch to create"
msgstr "생성할 배치 이름"

#: src/git_stage_batch/cli/argument_parser.py:340
msgid "Optional description for the batch"
msgstr "배치에 대한 설명 (선택사항)"

#: src/git_stage_batch/cli/argument_parser.py:347
msgid "List all batches"
msgstr "모든 배치 목록 표시"

#: src/git_stage_batch/cli/argument_parser.py:354
msgid "Delete a batch"
msgstr "배치 삭제"

#: src/git_stage_batch/cli/argument_parser.py:358
msgid "Name of the batch to delete"
msgstr "삭제할 배치 이름"

#: src/git_stage_batch/cli/argument_parser.py:365
msgid "Add or update batch description"
msgstr "배치 설명 추가 또는 업데이트"

#: src/git_stage_batch/cli/argument_parser.py:369
msgid "Name of the batch"
msgstr "배치 이름"

#: src/git_stage_batch/cli/argument_parser.py:373
msgid "Description text"
msgstr "설명 텍스트"

#: src/git_stage_batch/cli/argument_parser.py:380
msgid "Apply batch changes to working tree"
msgstr "작업 트리에 배치 변경사항 적용"

#: src/git_stage_batch/cli/argument_parser.py:387
msgid "Apply changes from batch to working tree"
msgstr "배치에서 작업 트리로 변경사항 적용"

#: src/git_stage_batch/cli/argument_parser.py:394
#: src/git_stage_batch/cli/argument_parser.py:401
msgid "Remove claims from batch"
msgstr "배치에서 청구 제거"

#: src/git_stage_batch/cli/argument_parser.py:408
msgid "Reset only specific line IDs (e.g., '1,3,5-7')"
msgstr "특정 라인 ID만 재설정 (예: '1,3,5-7')"

#: src/git_stage_batch/cli/dispatch.py:24
#: src/git_stage_batch/commands/status.py:72
