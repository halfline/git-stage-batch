#: src/git_stage_batch/cli/dispatch.py:25
#: src/git_stage_batch/commands/status.py:73
msgid "Run 'git-stage-batch start' to begin."
msgstr "'git-stage-batch start'를 실행하여 시작하세요."

#: src/git_stage_batch/commands/abort.py:30
