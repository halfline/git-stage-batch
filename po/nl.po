msgstr ""
"Kan niet locate anchor boundary after bronregel {line}: anchor not present "
"in realized content"

#: src/git_stage_batch/batch/merge.py:830
#, python-brace-format
msgid ""
"Anchor ambiguity: source line {line} appears {count} times in realized "
