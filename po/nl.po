msgstr ""
"Kan niet discard partial ownership of by-hunk replace region (bronregels "
"{start}-{end}): batch owns {owned} of {total} regels"

#: src/git_stage_batch/batch/merge.py:1494
#, python-brace-format
msgid "Unknown region kind: {kind}"
msgstr "Onbekend region kind: {kind}"

#: src/git_stage_batch/batch/merge.py:1698
#, python-brace-format
msgid ""
"Ownership conflict: line {line} is claimed by one batch but would be deleted"
