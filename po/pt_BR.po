#: src/git_stage_batch/batch/merge.py:945
#, python-brace-format
msgid "Cannot reliably place claimed line {line}: file completely rewritten"
msgstr ""
"Não é possível reliably place linha reivindicada {line}: arquivo completely "
"rewritten"

