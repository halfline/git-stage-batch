msgstr "These linhas must be selected together."

#: src/git_stage_batch/batch/selection.py:332
#, python-brace-format
msgid ""
"{explanation}\n"
"Use: --line {range}"
msgstr ""
"{explanation}\n"
"Use: --line {range}"

