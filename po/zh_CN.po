msgstr "没有正在进行的批次暂存会话。"

#: src/git_stage_batch/cli/dispatch.py:25
#: src/git_stage_batch/commands/status.py:72
msgid "Run 'git-stage-batch start' to begin."
msgstr "运行 'git-stage-batch start' 以开始。"

#: src/git_stage_batch/commands/abort.py:32
