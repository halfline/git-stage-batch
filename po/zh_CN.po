#, python-brace-format
msgid ""
"Batch metadata for '{name}' is missing required field: 'baseline'.\n"
"The metadata file may be corrupted."
msgstr ""
"批次 元数据 for '{name}' is missing required field: 'base行'.\n"
"The 元数据文件 may be corrupted."

