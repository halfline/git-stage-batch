msgstr ""
"无法 discard partial ownership of by-hunk replace region (源行s {start}-{end}): "
"批次 owns {owned} of {total} 行"

#: src/git_stage_batch/batch/merge.py:1494
#, python-brace-format
msgid "Unknown region kind: {kind}"
msgstr "未知 region kind: {kind}"

#: src/git_stage_batch/batch/merge.py:1698
#, python-brace-format
