msgstr "没有要中止的会话。未找到中止状态。"

#: src/git_stage_batch/commands/abort.py:50
msgid "Resetting to {}..."
msgstr "正在重置到 {}..."

#: src/git_stage_batch/commands/abort.py:61
msgid "Applying original changes..."
msgstr "正在应用原始更改..."

#: src/git_stage_batch/commands/abort.py:69
