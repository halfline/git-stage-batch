msgstr "✓ Applied new 二进制文件: {file}"

#: src/git_stage_batch/commands/apply_from.py:66
#, python-brace-format
msgid "✓ Replaced binary file: {file}"
msgstr "✓ Replaced 二进制文件: {file}"

#: src/git_stage_batch/commands/apply_from.py:71
#, python-brace-format
