msgstr "diff输出中的上下文行数（默认值：3）"

#: src/git_stage_batch/cli/argument_parser.py:431
msgid "Start interactive hunk-by-hunk mode"
msgstr "启动交互式逐块模式"

#: src/git_stage_batch/cli/argument_parser.py:438
msgid "Stop the selected session and clear state"
msgstr "停止当前会话并清除状态"

#: src/git_stage_batch/cli/argument_parser.py:446
msgid "Clear state and start a fresh pass"
msgstr "清除状态并开始新的过程"

#: src/git_stage_batch/cli/argument_parser.py:454
